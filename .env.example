AWS_REGION=eu-central-1
BEDROCK_NOVA_SONIC_REGION=us-east-1
BEDROCK_ALLOW_INSECURE_TLS=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

BEDROCK_NOVA_LITE_MODEL=eu.amazon.nova-lite-v1:0
BEDROCK_NOVA_PRO_MODEL=eu.amazon.nova-pro-v1:0
# Optional. If omitted, the API auto-tries Nova 2 Sonic and falls back to Nova Sonic v1.
# BEDROCK_NOVA_SONIC_MODEL=amazon.nova-2-sonic-v1:0
BEDROCK_NOVA_EMBED_MODEL=amazon.titan-embed-text-v2:0

S3_REDACTED_BUCKET=novatriage-redacted-dev
DYNAMODB_CASE_TABLE=NovaTriageCases

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

APP_LANGUAGE_DEFAULT=en
APP_PROTOCOL_DEFAULT=generic

MAX_UPLOAD_MB=50
ENABLE_OFFLINE_DRAFTS=true
