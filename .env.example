AWS_SECRET_ACCESS_KEY=placeholder_secret

BEDROCK_NOVA_LITE_MODEL=us.amazon.nova-lite-v1:0
BEDROCK_NOVA_PRO_MODEL=us.amazon.nova-pro-v1:0
BEDROCK_NOVA_SONIC_MODEL=amazon.nova-sonic-v1:0
